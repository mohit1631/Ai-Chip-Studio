# ==============================================
# AI Chip Studio — Phase 6 Environment Config
# ==============================================

# Server
NODE_ENV=development
PORT=3001

# PostgreSQL
DATABASE_URL=postgresql://chipstudio:password@localhost:5432/chipstudio

# Redis (Render Key Value / local Redis)
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_EXPIRES_IN=7d

# Ollama (self-hosted GPU host)
OLLAMA_HOST=http://your-gpu-host:11434
OLLAMA_MODEL=qwen2.5-coder:14b
OLLAMA_TIMEOUT_MS=120000

# Fallback to hosted frontier model (when Ollama is down)
OLLAMA_FALLBACK_ENABLED=true
ANTHROPIC_API_KEY=your-anthropic-api-key
ANTHROPIC_MODEL=claude-sonnet-4-6

# File upload limits
MAX_ZIP_SIZE_BYTES=52428800       # 50 MB
MAX_ZIP_FILE_COUNT=500
MAX_EXTRACTED_SIZE_BYTES=524288000 # 500 MB
UPLOAD_DIR=/tmp/chip-studio-uploads

# Docker worker config
DOCKER_LIGHT_IMAGE=chip-studio-light:latest
DOCKER_HEAVY_IMAGE=chip-studio-heavy:latest
DOCKER_NETWORK=chip-studio-net
WORKER_CPU_LIMIT=2
WORKER_MEMORY_LIMIT=4g
WORKER_TIMEOUT_MS=600000    # 10 min

# Rate limiting
RATE_LIMIT_WINDOW_MS=3600000   # 1 hour
RATE_LIMIT_FREE_MAX=100
RATE_LIMIT_PRO_MAX=1000
RATE_LIMIT_ENTERPRISE_MAX=10000

# Object storage (S3-compatible)
S3_ENDPOINT=https://your-s3-endpoint
S3_BUCKET=chip-studio-artifacts
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_REGION=us-east-1

# Encryption (AES-256 at rest)
ENCRYPTION_KEY=your-32-byte-hex-encryption-key-here

# Logging
LOG_LEVEL=info
